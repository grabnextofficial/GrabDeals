# Database (External Cloudflare Worker)
# URL of your deployed Cloudflare Worker that handles D1 queries
DATABASE_WORKER_URL=https://your-worker-name.your-username.workers.dev
# Secret key to authenticate requests to your Worker
DATABASE_SECRET_KEY=your_super_secret_key_here

# Authentication (Firebase)
# Get these from Firebase Console -> Project Settings
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Admin Configuration
# The email address that should automatically get Admin access
NEXT_PUBLIC_ADMIN_EMAIL=your_email@gmail.com

# File Storage (Optional - Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
